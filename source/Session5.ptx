<!--START TYPING CONTENT FOR SESSION BELOW HERE-->
<worksheet>
    <title> Session #5 (Sections 2.4 and 2.5)</title><!-- SECTION 1-->
    <p>
      Directions: Answer each of the following as best you can. Feel free to discuss your thoughts about the questions with some peers around you. 
      For additional practice problems and explanations, refer to the Math 142 textbook which is free and can be downloaded as a PDF 
      at <url href="https://oaktrust.library.tamu.edu/items/03980291-5e85-4d2e-a742-961ac49666aa"> Texas A&amp;M The OAKTrust Digital Repository </url>.
      <!--'&' and '<' are exceptional characters and are instead authored as &lt; and &amp;. See 4.1.4.2-->
    </p>
    
    <paragraphs>
        <title>Getting Warmed Up and in the Right Mindset</title>
    <exercise><!-- #1 --> <!-- controlling workspace length is the best way to force page breaks on a worksheet -->
      <statement>
        <p>
            Let <m>f</m> and <m>g</m> be two differentiable functions.
            Circle the correct Product Rule for derivatives.
            <md>
              <mrow>\text{Option 1:}\amp\quad \frac{d}{dx}(f(x) \cdot g(x)) = \left(\frac{d}{dx}f(x)\right)\cdot\left(\frac{d}{dx}g(x)\right)</mrow>
              <mrow>\text{Option 2:}\amp\quad \frac{d}{dx}(f(x) \cdot g(x)) = f(x)\cdot\left(\frac{d}{dx}g(x)\right)+g(x)\cdot \left(\frac{d}{dx}f(x)\right)</mrow>   
              <mrow>\text{Option 3:}\amp\quad \frac{d}{dx}(f(x) \cdot g(x)) = f(x)\cdot\left(\frac{d}{dx}g(x)\right)\cdot g(x)\cdot \left(\frac{d}{dx}f(x)\right)</mrow>   
            </md>       
        </p>
      </statement>
    </exercise>

    <exercise><!-- #2 -->
      <statement>
        <p>
            Let <m>f</m> and <m>g</m> be two differentiable functions.
            Circle the correct Quotient Rule for derivatives.
            <md>
              <mrow>\text{Option 1:}\amp\quad \frac{d}{dx}\left(\frac{f(x)}{g(x)}\right) = \frac{\frac{d}{dx}(f(x))}{\frac{d}{dx}(g(x))}</mrow>
              <mrow>\text{Option 2:}\amp\quad \frac{d}{dx}\left(\frac{f(x)}{g(x)}\right) = \frac{g(x)\cdot\left(\frac{d}{dx}f(x)\right)-f(x)\cdot \left(\frac{d}{dx}g(x)\right)}{g(x)}</mrow>
              <mrow>\text{Option 3:}\amp\quad \frac{d}{dx}\left(\frac{f(x)}{g(x)}\right) = \frac{g(x)\cdot\left(\frac{d}{dx}f(x)\right)-f(x)\cdot \left(\frac{d}{dx}g(x)\right)}{(g(x))^2}</mrow>    
            </md>
        </p>
      </statement>
    </exercise>

    <exercise><!-- #3 -->
      <statement>
        <p>
          Fill in the blanks to complete the special cases of the chain rule.
          <p>
          The Chain Rule: If <m>f</m> and <m>g</m> are differentiable functions, then
          <md>
            \frac{d}{dx}(f(g(x))) = f'(g(x))\cdot g'(x).
          </md>
          </p>
          <p>
            Special Cases of Chain Rule: If <m>g</m> is a differentiable function, <m>n</m> is any real number, and <m>b</m> is any positive real number, then
            <ul>
              <li>
                <p>
                 Generalized Power Rule: If <m>\displaystyle{y =(g(x))^n}</m>, then <m>\D y\;'= \rule{2in}{0.05mm}.</m>
                </p>
              </li>
              <li>
                <p>
                 Generalized Exponential (base <m>b</m>) Rule: If <m>\displaystyle{y =b^{g(x)}}</m>, then <m>\D y\;'= \rule{2in}{0.05mm}.</m>
                </p>
              </li>
              <li>
                <p>
                 Generalized Logarithm (base <m>b</m>) Rule: If <m>\displaystyle{y =\log_b(g(x))}</m>, then <m>\D y\;'=\rule{2in}{0.05mm}.</m>
                </p>
              </li>
            </ul>
          </p>
        </p>
      </statement>
    </exercise>
    </paragraphs>
    
    <paragraphs>
        <title>Let Us Get Our Hands On</title>
    <exercise workspace="1.5in" number="1"><!-- #1 --><!-- must restart numbering manually for each section -->
      <statement>
        <p>
          Find <m>\D f'(x)</m> given <m>\D f(x)=4x^{2}(3x^{2/3}+5x)</m>.
        </p>
      </statement>
    </exercise> 

    <exercise workspace="1.5in" number="2"><!-- #2 -->
      <statement>
        <p>
        Find <m>\D \frac{d}{dx}\bigg( 6x^{2} \cdot 3^{x} + \frac{3}{x^{-2}}\bigg)</m>
        </p>
      </statement>
    </exercise>
  
  
    <exercise workspace="2in" number="3"><!-- #3 -->
      <statement>
        <p> 
          Find the equation of the line tangent to the graph of <m>\D g(x)=\ln(x)\sqrt{x}</m> at <m>x=1</m>.
        </p>
      </statement>
    </exercise> 

    <exercise workspace="2in" number="4"><!-- #4 -->
      <statement>
        <p> 
          Determine if the work below is correct. If it is not correct, state why and work the problem correctly.  
        <md>  
            \text{Given} \ \ \D f(x)=\frac{\sqrt{x}}{2^x}, \quad \D f'(x)=\frac{\frac{d}{dx}\bigg(\sqrt{x}\bigg)}{\frac{d}{dx}\bigg( 2^x \bigg)}=\frac{\frac{1}{2}x^{-1/2}}{2^x\ln2}
        </md>
        </p>
      </statement>
    </exercise> 
  
    <exercise workspace="2in" number="5"><!-- #5 -->
      <statement>
        <p>
          Given <m>\D g(x)=\frac{\sqrt[3]{x^{2}}+3}{e^{x}-4x^{3}}</m>, find <m>\D g'(x)</m>.
        </p>
      </statement>
    </exercise> 
  
  
    <exercise number="6"><!-- #6 -->
      <introduction>
        <p> Find the derivatives of each function given below. Do not simplify your answers after  you have applied the appropriate derivative rules.</p>
      </introduction>
            <task workspace="1in">
              <p>
                <m>\D f(x) = e^{4x}</m>
              </p>
            </task>
            <task workspace="1in">
              <p>
                <m>\D f(x) = \sqrt{2x^{2}-e}</m>
              </p>
            </task>
            <task workspace="1in">
              <p>
                <m>\D f(x) = \ln(x^{2})+x-3^{x}</m>
              </p>
            </task>
            <task workspace="1in">
              <p>
                <m>\D f(x)=\sqrt{e^{x^2}+5x}</m>
              </p>
            </task>
            <task workspace="1in">
              <p>
                <m>\D h(x)=\log_{3}\left((x^{2/3}+4x)^{8}\right)</m>
              </p>
            </task>
            <task workspace="1in">
              <p>
                <m>\D f(x)=4\bigg(\frac{3}{x^{4}}+2^{x}\bigg)^{5}</m>
              </p>
            </task>
            <task workspace="1in">
              <p>
                <m>\D g(x)=\frac{3x}{\sqrt{e^{x^2}+5x}}</m>
              </p>
            </task>
            <task workspace="1in">
              <p>
                <m>\D h(x)=e^{4x}\ln\bigg(x^{2}+\sqrt{x}\bigg)</m>
              </p>
            </task>
    </exercise> 

    <exercise number="7"><!-- #7 -->
      <introduction>
        <p> Let <m>f(x)</m> be a differentiable function. The values of <m>f(x)</m> and <m>f'(x)</m> are given in the table below and the graph of <m>g(x)</m> is shown.</p>
            <sidebyside widths ="40% 50%" valign ="middle">
            <p>
              <image source="MATH142_HOGU_Session5_Fig1.png" width="50%">
              <shortdescription>Graph of a function plotted on coordinate axes. Refer to image description for more detail.</shortdescription>
              <description>
                <p>
                  Graph of a function <m>g(x)</m> plotted on coordinate axes. Starting on the left, the graph increases away from, but never touches, the horizontal asymptote
                  <m>y = -6</m>. The graph reaches a peak above the <m>x</m>-axis, and then decreases along, but never touching the vertical asymptote <m>x=3</m> until it leaves 
                  the coordinate axes. The graph then increases to the right of the vertical asymptote, approaching but not touching the horizontal asymptote <m>y = -6</m>
                  until it leaves the coordinate axes.
                </p>
              </description>
            </image> 
            </p>
            <p>
            <table><!--see chp 20 on Guide for how to create tables-->
              <title>Values of <m>f(x)</m> and <m>f'(x)</m></title>
              <tabular halign="center">
                <row header="yes" bottom="minor" >
                  <cell><m>x</m></cell>
                  <cell><m>f(x)</m></cell>
                  <cell><m>f'(x)</m></cell>
                </row>
                <row>
                  <cell><m>1</m></cell>
                  <cell><m>3</m></cell>
                  <cell><m>4</m></cell>
                </row>
                <row>
                  <cell><m>2</m></cell>
                  <cell><m>2</m></cell>
                  <cell><m>5</m></cell>
                </row>
                <row>
                  <cell><m>3</m></cell>
                  <cell><m>1</m></cell>
                  <cell><m>6</m></cell>
                </row>
              </tabular>
            </table>
            </p>
        </sidebyside>
        </introduction>
          <task workspace="1.5in">
            <p>
              Let <m>h(x)=g(f(x)).</m> Find <m>\D h'(3)</m>.
            </p>
          </task>
          <task workspace="1.5in">
            <p>
              Let <m>k(x)=f(g(x))</m>. Find <m>\D k'(1)</m>.
            </p>
          </task>
          <task workspace="1.5in">
            <p>
              Let <m>\D m(x)=\frac{h(x)}{x^{2}}</m>. Find <m>\D m'(3)</m>. (<em>Hint: Use part (a) to find <m>h(3)</m> and <m>h'(3)</m>.</em>)
            </p>
          </task>
    </exercise>  

    <exercise number="8"><!-- #8 -->
      <statement>
        <p> 
          Find all <m>x-</m>value(s) at which the tangent line to the curve <m>y = \frac{x^{2}-3}{2e^{x}}</m> is horizontal.
        </p>
      </statement>
    </exercise> 
    <exercise number="9"><!-- #9 -->
      <statement>
        <p> 
          The weekly profit for a company selling candles can be modeled by <m>P(x) = 0.7\sqrt{x^{5/2}-17}-137</m> dollars per <m>x</m> candles sold.
          Find the marginal profit when 200 candles are sold. Round your answer to the nearest cent.
        </p>
      </statement>
    </exercise> 
  
  </paragraphs>
  
    <paragraphs>
        <title>Now Grades Go Up</title>
      </paragraphs>
      <exercise number="1"><!-- #1 -->
        <statement>
          <p>
            The cost to produce <m>x</m> keychains in a day for a particular company is given by <m>C(x) = \sqrt{20x+2}+175</m> dollars.
            Use marginal analysis to approximate the cost of producing the 10th keychain.
              <ol marker="(a)">
                <li> <p><m>\$ 0.22</m></p> </li>
                <li> <p> <m>\$ 0.11</m></p> </li>
                <li> <p><m>\$ 0.72</m> </p> </li>
                <li> <p> <m>\$ 0.74</m></p> </li>
              </ol>
          </p>
        </statement>
      </exercise>
      
      <exercise number="2"><!-- #2 -->
        <statement>
          <p>
            The derivative of <m>f(x) = \frac{13x^{2}}{e^{x}+1}</m> is
              <ol marker="(a)">
                <li> <p> <m>\D f'(x) = \frac{13x^2e^x-26x(e^x+1)}{(e^x+1)^2}</m></p> </li>
                <li> <p> <m>\D f'(x) = \frac{13x^2-e^x-1}{e^x+1}</m></p> </li>
                <li> <p> <m>\D f'(x) = \frac{26x(e^x+1)-13x^2e^x}{e^x+1} </m> </p></li>
                <li> <p><m>\D f'(x) = \frac{26x(e^x+1)-13x^2e^x}{(e^x+1)^2}</m> </p> </li>
              </ol>
          </p>
        </statement>
      </exercise>

      <exercise workspace ="1in" number="3"><!-- #3 -->
        <statement>
          <p>
            Find <m>h'(2)</m> given that <m>f(2) = -2,</m> <m>f'(2) = 5</m>, and <m>h(x) = (3x^{2})\cdot f(x)</m>
              <ol marker="(a)">
                <li> <p> <m>12</m> </p> </li>
                <li> <p> <m>60</m> </p> </li>
                <li> <p> <m>-24</m>  </p> </li>
                <li> <p> <m>36</m> </p> </li>
                <li> <p> <m>-60</m> </p> </li>
              </ol>
          </p>
        </statement>
      </exercise>

  </worksheet>

